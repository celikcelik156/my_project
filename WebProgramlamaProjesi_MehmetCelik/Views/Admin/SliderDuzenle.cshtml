@model WebProgramlamaProjesi_MehmetCelik.Models.Slider

@{
    ViewBag.Title = "Edit Slider";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="section-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h1 class="page-header">Edit Slider</h1>
            </div>
        </div>
    </div>
</div>

<div class="container container-int">
    @using (Html.BeginForm("SliderDuzenle", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(model => model.Id)
        @Html.HiddenFor(model => model.ResimYolu)

        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(model => model.Baslik, "Title", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.Baslik, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.Baslik, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.Aciklama, "Description", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.TextAreaFor(model => model.Aciklama, new { @class = "form-control", rows = "3" })
                    @Html.ValidationMessageFor(model => model.Aciklama, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.Label("Slider Resmi", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @if (!string.IsNullOrEmpty(Model.ResimYolu))
                    {
                        <div style="margin-bottom: 15px;">
                            <p><strong>Mevcut Resim:</strong></p>
                            <img src="@Model.ResimYolu" style="max-width: 300px; height: auto; border: 1px solid #ccc; padding: 5px;" />
                        </div>
                    }

                    <p>Resmi deđiţtirmek isterseniz yeni dosya seçin:</p>
                    <input type="file" name="ResimDosyasi" class="form-control" accept=".jpg,.png,.jpeg" />
                    @Html.ValidationMessageFor(model => model.ResimYolu, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.Link, "Link URL", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.Link, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.Link, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.LinkMetni, "Link Text", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.LinkMetni, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.LinkMetni, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.Aktif, "Active", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    <div class="checkbox">
                        @Html.EditorFor(model => model.Aktif)
                        @Html.ValidationMessageFor(model => model.Aktif, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <input type="submit" value="Update" class="btn btn-primary" />
                    <a href="@Url.Action("SliderListesi")" class="btn btn-default">Cancel</a>
                </div>
            </div>
        </div>
    }
</div>
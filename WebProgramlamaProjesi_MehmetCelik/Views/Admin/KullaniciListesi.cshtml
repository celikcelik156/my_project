@model IEnumerable<WebProgramlamaProjesi_MehmetCelik.Models.Kullanici>

@{
    ViewBag.Title = "User List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<script type="text/javascript">
    var js = jQuery.noConflict(true);
    js(document).ready(function () {
        js('#myTable').DataTable(
            {
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.25/i18n/Turkish.json"
                }
            }
        );
    }
    );
</script>

<div class="section-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h1 class="page-header">User Management</h1>
            </div>
        </div>
    </div>
</div>

<div class="container container-int">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            @TempData["ErrorMessage"]
        </div>
    }

    <p>
        <a href="@Url.Action("Index")" class="btn btn-default">Admin Panel</a>
    </p>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-bordered" id="myTable">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Admin</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.KullaniciAdi</td>
                        <td>@(string.IsNullOrEmpty(item.AdSoyad) ? "-" : item.AdSoyad)</td>
                        <td>@item.Email</td>
                        <td>
                            @if (item.Admin)
                            {
                                <span class="label label-danger">Admin</span>
                            }
                            else
                            {
                                <span class="label label-info">User</span>
                            }
                        </td>
                        <td>
                            @if (item.Aktif)
                            {
                                <span class="label label-success">Active</span>
                            }
                            else
                            {
                                <span class="label label-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("KullaniciDuzenle", new { id = item.Id })" class="btn btn-sm btn-warning">Edit</a>
                            <a href="@Url.Action("KullaniciAktifPasif", new { id = item.Id })" class="btn btn-sm @(item.Aktif ? "btn-danger" : "btn-success")" onclick="return confirm('Are you sure you want to @(item.Aktif ? "deactivate" : "activate") this user?');">
                                @(item.Aktif ? "Deactivate" : "Activate")
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fa fa-info-circle"></i> No users found.
        </div>
    }
</div>


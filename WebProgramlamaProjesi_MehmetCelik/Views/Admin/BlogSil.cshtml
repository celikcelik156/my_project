@model WebProgramlamaProjesi_MehmetCelik.Models.Blog

@{
    ViewBag.Title = "Delete Blog";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="section-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h1 class="page-header">Delete Blog</h1>
            </div>
        </div>
    </div>
</div>

<div class="container container-int">
    <h3>Are you sure you want to delete this blog post?</h3>
    <div>
        <dl class="dl-horizontal">
            <dt>Title:</dt>
            <dd>@Model.Baslik</dd>

            <dt>Author:</dt>
            <dd>@Model.Yazar</dd>

            <dt>Creation Date:</dt>
            <dd>@Model.OlusturmaTarihi.ToString("dd.MM.yyyy")</dd>
        </dl>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="form-actions no-color">
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a href="@Url.Action("BlogListesi")" class="btn btn-default">Cancel</a>
            </div>
        }
    </div>
</div>
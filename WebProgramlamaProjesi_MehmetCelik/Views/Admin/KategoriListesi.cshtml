@model IEnumerable<WebProgramlamaProjesi_MehmetCelik.Models.Kategori>

@{
    ViewBag.Title = "Category List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<script type="text/javascript">
    var js = jQuery.noConflict(true);
    js(document).ready(function () {
        js('#myTable').DataTable(
            {
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.25/i18n/Turkish.json"
                }
            }
        );
    }
    );
</script>

<div class="section-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h1 class="page-header">Category Management</h1>
            </div>
        </div>
    </div>
</div>

<div class="container container-int">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            @TempData["ErrorMessage"]
        </div>
    }

    <p>
        <a href="@Url.Action("KategoriEkle")" class="btn btn-primary">Add New Category</a>
        <a href="@Url.Action("Index")" class="btn btn-default">Admin Panel</a>
    </p>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-bordered" id="myTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Ad</td>
                        <td>@(string.IsNullOrEmpty(item.Aciklama) ? "-" : item.Aciklama)</td>
                        <td>
                            <a href="@Url.Action("KategoriDuzenle", new { id = item.Id })" class="btn btn-sm btn-warning">Edit</a>
                            <a href="@Url.Action("KategoriSil", new { id = item.Id })" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this category?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fa fa-info-circle"></i> No categories found. <a href="@Url.Action("KategoriEkle")">Click here</a> to add your first category.
        </div>
    }
</div>
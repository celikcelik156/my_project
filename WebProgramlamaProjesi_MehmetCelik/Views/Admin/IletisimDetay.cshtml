@model WebProgramlamaProjesi_MehmetCelik.Models.Iletisim

@{
    ViewBag.Title = "Contact Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="section-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h1 class="page-header">Contact Message Details</h1>
            </div>
        </div>
    </div>
</div>

<div class="container container-int">
    <div class="panel panel-default">
        <div class="panel-heading">
            <h3>Message Details</h3>
        </div>
        <div class="panel-body">
            <dl class="dl-horizontal">
                <dt><strong>Name:</strong></dt>
                <dd>@Model.Ad</dd>

                <dt><strong>Email:</strong></dt>
                <dd><a href="mailto:@Model.Email">@Model.Email</a></dd>

                <dt><strong>Phone:</strong></dt>
                <dd>@(string.IsNullOrEmpty(Model.Telefon) ? "-" : Model.Telefon)</dd>

                <dt><strong>Date:</strong></dt>
                <dd>@Model.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</dd>

                <dt><strong>Read:</strong></dt>
                <dd>
                    @if (Model.Okundu)
                    {
                        <span class="label label-success">Yes</span>
                    }
                    else
                    {
                        <span class="label label-warning">No</span>
                    }
                </dd>

                <dt><strong>Message:</strong></dt>
                <dd>
                    <div class="well" style="margin-top: 10px;">
                        @Html.Raw(Model.Mesaj)
                    </div>
                </dd>
            </dl>
        </div>
        <div class="panel-footer">
            <a href="@Url.Action("IletisimListesi")" class="btn btn-default"><i class="fa fa-arrow-left"></i> Back to List</a>
            <a href="@Url.Action("IletisimSil", new { id = Model.Id })" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this message?');"><i class="fa fa-trash"></i> Delete</a>
        </div>
    </div>
</div>
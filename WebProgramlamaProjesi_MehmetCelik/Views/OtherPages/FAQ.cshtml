@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h1 class="page-header">FAQ <small>Frequently Asked Questions</small></h1>
            </div>
        </div>
    </div>
</div>

<div class="container container-int">
    <div class="row">
        <div class="col-lg-12">
            <ol class="breadcrumb">
                <li><a href="@Url.Action("Index", "Home")">Home</a></li>
                <li class="active">FAQ</li>
            </ol>

            <div class="panel-group" id="accordion">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseOne">
                                What services does Algocak offer?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseOne" class="panel-collapse collapse">
                        <div class="panel-body">
                            Algocak offers a comprehensive range of digital services including web design and development, mobile application development, digital marketing, SEO optimization, content management, e-commerce solutions, and ongoing technical support. We tailor our services to meet your specific business needs.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseTwo">
                                How long does it take to complete a web design project?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseTwo" class="panel-collapse collapse">
                        <div class="panel-body">
                            The timeline for web design projects varies depending on the complexity and scope of the project. A simple website typically takes 2-4 weeks, while more complex projects may take 6-12 weeks. We provide detailed project timelines during our initial consultation and keep you updated throughout the development process.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseThree">
                                Do you provide ongoing support and maintenance?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseThree" class="panel-collapse collapse">
                        <div class="panel-body">
                            Yes, we offer comprehensive support and maintenance packages to ensure your website remains secure, up-to-date, and performing optimally. Our support services include regular updates, security monitoring, backup services, and technical assistance. We offer flexible support plans to suit your needs and budget.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseFour">
                                Can you help with SEO and digital marketing?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseFour" class="panel-collapse collapse">
                        <div class="panel-body">
                            Absolutely! Algocak provides comprehensive SEO and digital marketing services to help improve your online visibility and drive more traffic to your website. Our services include keyword research, on-page and off-page SEO, content marketing, social media management, and pay-per-click advertising campaigns.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseFive">
                                What is your pricing structure?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseFive" class="panel-collapse collapse">
                        <div class="panel-body">
                            Our pricing is customized based on the specific requirements of your project. We offer transparent pricing with no hidden fees. During our initial consultation, we'll discuss your needs and provide a detailed quote. We also offer flexible payment plans to accommodate different budgets.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseSix">
                                Do you work with businesses of all sizes?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseSix" class="panel-collapse collapse">
                        <div class="panel-body">
                            Yes, Algocak works with businesses of all sizes, from startups to large enterprises. We understand that each business has unique needs and challenges, and we tailor our services accordingly. Whether you're just starting out or looking to enhance your existing digital presence, we're here to help.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseSeven">
                                How do I get started with Algocak?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseSeven" class="panel-collapse collapse">
                        <div class="panel-body">
                            Getting started is easy! Simply contact us through our contact page or reach out via email or phone. We'll schedule a free consultation to discuss your project, understand your goals, and provide recommendations. From there, we'll create a customized proposal and timeline for your project.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseEight">
                                Will I be able to update my website myself?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseEight" class="panel-collapse collapse">
                        <div class="panel-body">
                            Yes, we build websites with user-friendly content management systems that allow you to easily update content, add new pages, upload images, and make other changes without technical knowledge. We also provide training and documentation to help you manage your website effectively.
                        </div>
                    </div>
                </div>

                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a class="accordion-toggle" data-toggle="collapse" data-parent="#accordion" href="#collapseNine">
                                What technologies do you use?
                            </a>
                        </h4>
                    </div>
                    <div id="collapseNine" class="panel-collapse collapse">
                        <div class="panel-body">
                            We use modern, industry-standard technologies and frameworks to build robust, scalable, and secure websites. Our technology stack includes ASP.NET, responsive design frameworks, various content management systems, and cloud hosting solutions. We stay up-to-date with the latest trends and best practices in web development.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


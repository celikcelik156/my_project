@model IEnumerable<WebProgramlamaProjesi_MehmetCelik.Models.Portfolio>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h1 class="page-header">Portfolio</h1>
            </div>
        </div>
    </div>
</div>

<div class="container container-int">
    <ol class="breadcrumb">
        <li><a href="@Url.Action("Index", "Home")">Home</a></li>
        <li class="active">Portfolio</li>
    </ol>

    @if (Model != null && Model.Any())
    {
        foreach (var portfolio in Model)
        {
            <div class="row">
                <div class="col-md-7 col-sm-7">
                    <a href="@Url.Action("Details", "Portfolio", new { id = portfolio.Id })">
                        <img class="img-responsive" src="@portfolio.ResimYolu" alt="@portfolio.Baslik">
                    </a>
                </div>

                <div class="col-md-5 col-sm-5">
                    <h3>@portfolio.Baslik</h3>
                    @if (!string.IsNullOrEmpty(portfolio.Aciklama))
                    {
                        <p>@portfolio.Aciklama</p>
                    }
                    <a class="btn btn-primary" href="@Url.Action("Details", "Portfolio", new { id = portfolio.Id })">View Project <i class="fa fa-angle-right"></i></a>
                </div>
            </div>
            <hr>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="fa fa-info-circle"></i> No portfolio items available.
        </div>
    }
</div>


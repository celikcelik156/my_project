@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password</title>
    <link rel="stylesheet" href="~/algocak/css/Giris_Kayit.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />
    <style>
        html {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        
        body {
            margin: 0;
            padding: 20px;
            background-image: url('/algocak/img/section-bg.png');
            background-size: cover;
            background-position: center center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-color: #2e5e6d;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            font-family: "Poppins", sans-serif;
            min-height: 100vh;
            height: 100%;
            width: 100%;
            position: relative;
        }
        
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(75, 182, 183, 0.6) 0%, rgba(46, 94, 109, 0.6) 100%);
            z-index: -1;
        }

        .forgot-password-container {
            border-radius: 25px;
            box-shadow: 0 14px 28px rgba(0, 0, 0, 0.25), 0 0px 10px rgba(0, 0, 0, 0.22);
            position: relative;
            overflow: hidden;
            width: 500px;
            max-width: 100%;
            /* Yükseklik içeriğe göre esnesin */
            min-height: 400px;
            background-color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .forgot-password-form {
            background-color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            padding: 40px 50px;
            height: 100%;
            text-align: center;
        }

        .forgot-password-container h1 {
            font-weight: 700;
            margin: 0 0 15px 0;
            color: #333;
            font-size: 28px;
        }

        .forgot-password-container p {
            font-size: 14px;
            font-weight: 400;
            line-height: 1.5;
            margin: 10px 0 30px;
            color: #666;
        }

        .form-control-forgot {
            width: 100%;
            position: relative;
            margin: 15px 0;
        }

            .form-control-forgot input {
                background-color: #f4f8f7;
                border: none;
                padding: 12px 15px;
                margin: 8px 0;
                width: 100%;
                font-size: 14px;
                border-radius: 5px;
                outline: none;
            }

        button.btn-forgot {
            border-radius: 20px;
            border: 1px solid #4bb6b7;
            background-color: #4bb6b7;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            padding: 12px 45px;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: transform 80ms ease-in;
            cursor: pointer;
            margin-top: 20px;
        }

            button.btn-forgot:hover {
                background-color: #3aa3a4;
            }

            button.btn-forgot:active {
                transform: scale(0.95);
            }

        .back-link {
            margin-top: 25px;
        }

            .back-link a {
                color: #333;
                font-size: 14px;
                text-decoration: none;
                font-weight: 600;
                transition: color 0.3s;
            }

                .back-link a:hover {
                    color: #4bb6b7;
                }

                .back-link a i {
                    margin-right: 5px;
                }

        /* Alert Styles */
        .alert {
            padding: 12px;
            border-radius: 5px;
            margin-bottom: 20px;
            font-size: 14px;
            width: 100%;
            text-align: left;
        }

        .alert-success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .alert i {
            margin-right: 5px;
        }
    </style>
</head>
<body>
    <div class="forgot-password-container">
        <div class="forgot-password-form">
            <h1><i class="fa fa-lock"></i> Forgot Password?</h1>
            <p>Don't worry! Enter your email address below and we will send you a link to reset your password.</p>

            @if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success">
                    <i class="fa fa-check-circle"></i> @ViewBag.SuccessMessage
                </div>
            }

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-error">
                    <i class="fa fa-exclamation-circle"></i> @ViewBag.ErrorMessage
                </div>
            }

            @using (Html.BeginForm("SifremiUnuttum", "Giris", FormMethod.Post, new { style = "width: 100%;" }))
            {
                @Html.AntiForgeryToken()

                <div class="form-control-forgot">
                    <input type="email" name="email" placeholder="Email Address" required autofocus>
                </div>

                <button type="submit" class="btn-forgot">
                    Send Reset Link
                </button>
            }

            <div class="back-link">
                <a href="@Url.Action("Giris", "Giris")"><i class="fa fa-arrow-left"></i> Back to Sign In</a>
            </div>
        </div>
    </div>
</body>
</html>
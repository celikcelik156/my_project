        private Panel WrapTextBoxWithPanel(TextBox tb)
        {
            if (tb == null || tb.Parent == null)
                return null;
n            var parent = tb.Parent;
            int index = parent.Controls.GetChildIndex(tb);
            var location = tb.Location;
            var size = tb.Size;
            var anchor = tb.Anchor;
            var tabIndex = tb.TabIndex;
n            // Remove textbox from current parent
            parent.Controls.Remove(tb);
n            // Create panel to act as colored border
            var panel = new Panel
            {
                Location = location,
                Size = size,
                Anchor = anchor,
                Padding = new Padding(1),
                BackColor = textboxBorderDefault,
                TabIndex = tabIndex,
                Name = tb.Name + "_panel"
            };
n            // Configure textbox to fill panel
            tb.BorderStyle = BorderStyle.None;
            tb.Margin = new Padding(0);
            tb.Dock = DockStyle.Fill;
n            panel.Controls.Add(tb);
n            // Insert panel into original parent at same index
            parent.Controls.Add(panel);
            parent.Controls.SetChildIndex(panel, index);
n            // Odağı takip et
            tb.GotFocus += (s, e) => panel.BackColor = Color.DodgerBlue;
            tb.LostFocus += (s, e) => panel.BackColor = textboxBorderDefault;
n            return panel;
        }

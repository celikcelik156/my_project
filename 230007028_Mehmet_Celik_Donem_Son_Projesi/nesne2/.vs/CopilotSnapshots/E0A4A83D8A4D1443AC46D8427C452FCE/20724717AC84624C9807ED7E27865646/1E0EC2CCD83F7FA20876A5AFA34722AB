        private void button2_Click(object sender, EventArgs e)
        {
            string kullanici_adi = textBox1.Text;
            string sifre = textBox2.Text;
            bool isAdmin = true;
            bool isThere = false;
            bool isThereAdmin = false;

            connection.Open();

            SqlCommand command = new SqlCommand("SELECT * FROM Personel", connection);
            SqlDataReader reader = command.ExecuteReader();

            while (reader.Read())
            {
                if (kullanici_adi == reader["Eposta"].ToString().TrimEnd() && sifre == reader["sifre"].ToString().TrimEnd())
                {
                    isThere = true;

                    if (isAdmin.ToString() == reader["isAdmin"].ToString().TrimEnd())
                    {
                        isThereAdmin = true;
                    }
                }
            }

            if (isThere == true)
            {
                if (isThereAdmin == true)
                {
                    MessageBox.Show("Giriş Başarılı! Admin sayfasına gidiyorsun!!!", "Bilgi", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    connection.Close();
                    this.Hide();
                    return;
                }
                else
                {
                    MessageBox.Show("Giriş Başarılı!", "Bilgi", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    connection.Close();
                    this.Hide();
                    return;
                }
            }
            else
            {
                MessageBox.Show("Kullanıcı adı veya şifre yanlış!", "Hata", MessageBoxButtons.OK, MessageBoxIcon.Error);
                connection.Close();
                return;
            }

        }

